{
  "name": "@quranmiracle/mcp",
  "version": "0.1.0",
  "description": "MCP server for Quranic data - 77,851 words, 324,646 letters with grammar-aware search, ebced calculations, and linguistic analysis",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "data/qurandb.sqlite"
  ],
  "scripts": {
    "build:db": "tsx scripts/build-db.ts",
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "check": "tsc --noEmit && eslint src/",
    "prepublishOnly": "npm run build:db && npm run build"
  },
  "keywords": [
    "mcp",
    "quran",
    "arabic",
    "islamic",
    "nlp",
    "database",
    "ebced",
    "abjad"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.8.1",
    "express": "^5.2.1",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "eslint": "^10.0.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-secrets": "^2.2.2",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1"
  }
}
